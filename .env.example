# ── Chatbot provider switch ───────────────────────────────
# "gemini" (free), "openrouter" (testing), or "openai" (production)
AI_PROVIDER=gemini

# Google Gemini (free tier) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter (OpenAI-compatible, for testing) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# OpenAI (production) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
