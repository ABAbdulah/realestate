# ── Chatbot provider switch ───────────────────────────────
# "gemini" (free, for dev/testing) or "openai" (production)
AI_PROVIDER=gemini

# Google Gemini (free tier) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (production) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
